POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb
DATABASE_URL=postgresql+psycopg2://user:password@db:5432/mydb
PORT_DB=5433
PORT_API=8008
PORT_FRONTEND=5173
HOST_REDIS=redis
PORT_REDIS=6379
OPEN_WEATHER_API_KEY=[your_open_weather_api_key_here]
QWEATHER_API_KEY=
QWEATHER_API_HOST=
VITE_API_URL=
ENABLE_WEBODM=false
WEBODM_PATH=
WEBODM_URL=
WEBODM_USERNAME=admin
WEBODM_PASSWORD=admin
ARGUS_OLLAMA_PORT=11434
LOG_LEVEL=WARNING

# YOLO detection quality profile. On an NVIDIA gaming laptop, use the
# nvidia compose override and set quality/ensemble to use larger models and
# higher image sizes without changing uploaded image quality.
ARGUS_YOLO_PRESET=balanced
ARGUS_YOLO_ENSEMBLE=false
ARGUS_YOLO_IMGSZ=640
ARGUS_FALLBACK_YOLO_IMGSZ=1280
ARGUS_ULTRALYTICS_YOLO_ENABLED=false
ARGUS_ULTRALYTICS_YOLO_MODEL=yolo11x.pt
ARGUS_ULTRALYTICS_YOLO_IMGSZ=1280
ARGUS_YOLO_CONF=0.15
ARGUS_YOLO_IOU=0.50
ARGUS_YOLO_AUGMENT=false
ARGUS_YOLO_TILE_DEPTHS=2
ARGUS_YOLO_TILE_OVERLAP=0.25
ARGUS_YOLO_TILE_BATCH_SIZE=8

# AI description provider:
# - ollama: local Ollama container
# - openai: OpenAI API
# - gemini: Google Gemini API
# - openai_compatible: China-friendly OpenAI-compatible APIs, e.g. Qwen/DashScope or compatible gateways
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_VISION_MODEL=llava:v1.6
LLM_TEXT_MODEL=llama3.2
LLM_TRANSLATE_TO=chinese
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
